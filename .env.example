# Copie ce fichier en .env et remplis avec tes vraies infos SMTP
# (ou exporte ces variables directement dans ton terminal)
#
# Si ces variables ne sont pas definies, l'app fonctionne quand meme :
# les alertes sont juste "simulees" (dry run) au lieu d'etre vraiment
# envoyees, donc tu peux tester sans avoir de compte email dedie.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton-adresse@gmail.com
SMTP_PASSWORD=ton-mot-de-passe-app
ALERT_EMAIL_TO=destinataire-des-alertes@exemple.com
